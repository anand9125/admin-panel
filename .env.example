# ─── Auth (Google OAuth via Auth.js / next-auth v5) ──────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=
# Google OAuth client (same Google Cloud project as ops is fine — just add this
# app's callback URL: https://<your-domain>/api/auth/callback/google)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# In production behind a proxy/Vercel, set the canonical URL + trust the host.
AUTH_URL=https://access.trenchers.ai
AUTH_TRUST_HOST=true

# ─── Who may use this panel ──────────────────────────────────────────────────
# Company Workspace domain (default: trenchers.ai). Only verified accounts on
# this domain can ever sign in.
ACCESS_PANEL_DOMAIN=trenchers.ai
# OPTIONAL per-person gate. If set (comma-separated), ONLY these addresses may
# use the panel. Leave blank to allow any @ACCESS_PANEL_DOMAIN account.
# ACCESS_PANEL_ALLOWED_EMAILS=alice@trenchers.ai,bob@trenchers.ai

# ─── Backend whitelist API (solana-terminal) ─────────────────────────────────
# The panel calls the same service-token-guarded admin API that ops uses. These
# are SERVER-ONLY (no NEXT_PUBLIC_ prefix) so the token never reaches the browser.
#
# Production (configure at minimum this one):
SOLANA_TERMINAL_API_URL_PRODUCTION=https://api.trenchers.ai
OPS_SERVICE_TOKEN_PRODUCTION=
#
# Staging (optional — omit to hide the staging tab):
# SOLANA_TERMINAL_API_URL_STAGING=https://staging-api.trenchers.ai
# OPS_SERVICE_TOKEN_STAGING=
#
# Shared fallbacks (used when the per-env vars above are absent):
# SOLANA_TERMINAL_API_URL=
# OPS_SERVICE_TOKEN=

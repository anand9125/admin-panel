# ─── Auth (Google OAuth via Auth.js / next-auth v5) ──────────────────────────
AUTH_SECRET=                         # openssl rand -base64 32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_URL=https://admin.trenchers.ai  # canonical URL in prod
AUTH_TRUST_HOST=true

# Who may reach the panel
ADMIN_ALLOWED_DOMAIN=trenchers.ai
# ADMIN_ALLOWED_EMAILS=alice@trenchers.ai,bob@trenchers.ai   # optional per-person gate

# ─── solana-terminal backend (ops-token stack) ───────────────────────────────
# The panel calls /admin/whitelist* and /admin/users* with the shared X-Ops-Token.
# Server-only (no NEXT_PUBLIC_) so the token never reaches the browser.
# The token MUST match OPS_SERVICE_TOKEN on the solana-terminal backend.
#
# Production:
SOLANA_TERMINAL_API_URL_PRODUCTION=https://api.trenchers.ai
OPS_SERVICE_TOKEN_PRODUCTION=
#
# Staging (optional):
# SOLANA_TERMINAL_API_URL_STAGING=https://staging-api.trenchers.ai
# OPS_SERVICE_TOKEN_STAGING=
#
# Shared fallbacks (used when a per-env var above is absent):
# SOLANA_TERMINAL_API_URL=
# OPS_SERVICE_TOKEN=
